<?xml version="1.0" encoding="utf-8"?>



<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fab_leave"

    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F5F9"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Header: Time + Request Leave -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp">

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8:22"
                    android:textSize="18sp"
                    android:textColor="#1E293B"
                    android:fontFamily="sans-serif-medium"
                    android:background="#F1F5F9"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Request Leave"
                    android:textSize="22sp"
                    android:textColor="#0B1B33"
                    android:fontFamily="sans-serif-medium"
                    android:textAlignment="textEnd" />
            </LinearLayout>

            <!-- First Day of Leave -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bottom_border">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="First Day of Leave"
                    android:textSize="14sp"
                    android:textColor="#5E6F8D"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wed 4 Aug 2021"
                        android:textSize="16sp"
                        android:textColor="#0F1D3A"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All Day"
                        android:textSize="11sp"
                        android:textColor="#1D4ED8"
                        android:fontFamily="sans-serif-medium"
                        android:background="#EEF6FF"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="2dp"
                        android:textAllCaps="true"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Last Day of Leave -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bottom_border">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Last Day of Leave"
                    android:textSize="14sp"
                    android:textColor="#5E6F8D"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fri 6 Aug 2021"
                        android:textSize="16sp"
                        android:textColor="#0F1D3A"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All Day"
                        android:textSize="11sp"
                        android:textColor="#1D4ED8"
                        android:fontFamily="sans-serif-medium"
                        android:background="#EEF6FF"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="2dp"
                        android:textAllCaps="true"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Days Total -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bottom_border">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Days Total"
                    android:textSize="14sp"
                    android:textColor="#5E6F8D"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/tvDaysTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textSize="16sp"
                    android:textColor="#1D4ED8"
                    android:fontFamily="sans-serif-medium"
                    android:background="#EEF6FF"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>

            <!-- Comments -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bottom_border">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Comments"
                    android:textSize="14sp"
                    android:textColor="#5E6F8D"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Moving house"
                    android:textSize="16sp"
                    android:textColor="#0F1D3A"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Leave Type -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bottom_border">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Leave Type"
                    android:textSize="14sp"
                    android:textColor="#5E6F8D"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Annual Leave (Vacation)"
                    android:textSize="16sp"
                    android:textColor="#0F1D3A"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Notify Manager -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Notify Manager"
                    android:textSize="14sp"
                    android:textColor="#5E6F8D"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grace Liu"
                    android:textSize="16sp"
                    android:textColor="#0F1D3A"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>